        ..registerCustomPanelAbilityTooltip(asList(ABIL_RAIN_OF_FIRE, ABIL_BURNING_ATTACK_1_ORB))
        ..setNormalAbilities(commaList(ABIL_RAIN_OF_FIRE, ABIL_AC_RAIN_OF_FIRE, ABIL_BURNING_ATTACK_1_ORB))
        ..setDefaultActiveAbility(commaList(ABIL_AC_RAIN_OF_FIRE))
        ..registerTooltipGenerator(tooltip)
        ..tooltipStartListen()

        ..setAttack1Data(AttackType.Magic, 105, 5, 9, 1.6)
        ..setAttack1Range(600)
        ..setAttack1ProjectileSpeed(900)
        ..setAttack1ProjectileArt(Abilities.redDragonMissile)
        ..setSmallSplash()

        ..setArmorData(ArmorType.Medium, 2)
        ..setHitPointsMaximumBase(900)
        ..setMana(200)


        ..setSizeLarge()
        ..setAutoPointValue()
        ..setAutoBuildingCost()

        ..setNameEnhance("Z", "Eredar Commander")
        ..setScalingValue(1.4)
        ..setBuildingScalingValue(1.4)

        ..tooltipStopListen()

        ..setBuildingScalingValue(0.7)
        ..setModelFileExt(Units.eredarWarlock)
        ..setIconGameInterfaceExt(Icons.bTNKiljaedin)
        ..setUnitSoundSetExt(Soundsets.tichondrius)
        ..setButtonPositionX(1)

    tooltip = new UnitTooltipGenerator(
        abilTooltipMap.get(ABIL_INFERNO) + "\n\n" +
        abilTooltipMap.get(ABIL_BURNING_ATTACK_2_ORB))
    createSpawnedUnit(UNIT_EREDAR_LORD, UnitIds.eredarsorceror, BUILDING_EREDAR_LORD)
        ..setSpeedBase(270)
        ..registerCustomPanelAbilityTooltip(asList(ABIL_INFERNO, ABIL_BURNING_ATTACK_2_ORB))
        ..setNormalAbilities(commaList(ABIL_INFERNO, ABIL_AC_INFERNO, ABIL_BURNING_ATTACK_2_ORB))
        ..setDefaultActiveAbility(commaList(ABIL_AC_INFERNO))
        // ..setNormalAbilities(commaList(""))
        ..registerTooltipGenerator(tooltip)
        ..tooltipStartListen()

        ..setAttack1Data(AttackType.Magic, 125, 5, 13, 1.6)
        ..setAttack1Range(600)
        ..setAttack1ProjectileSpeed(900)
        ..setAttack1ProjectileArt(Abilities.greenDragonMissile)
        ..setSmallSplash()

        ..setArmorData(ArmorType.Medium, 4)
        ..setHitPointsMaximumBase(1300)
        ..setMana(200)


        ..setSizeLarge()
        ..setAutoPointValue()
        ..setAutoBuildingCost()

        ..setNameEnhance("X", "Eredar Lord")
        ..setScalingValue(1.6)
        ..setBuildingScalingValue(1.6)

        ..tooltipStopListen()

        ..setBuildingScalingValue(0.8)
        ..setModelFileExt(Units.warlock)
        ..setIconGameInterfaceExt(Icons.bTNArchimonde)
        ..setUnitSoundSetExt(Soundsets.tichondrius)
        ..setButtonPositionX(1)


    tooltip = new UnitTooltipGenerator(
        abilTooltipMap.get(ABIL_CLEAVE_20) + "\n\n" +
        abilTooltipMap.get(ABIL_IMMOLATION) + "\n\n" +
        "Summoned by Eredar Lord."
        )
    createSpawnedUnit(UNIT_INFERNAL, UnitIds.infernal)
        ..setSpeedBase(270)
        ..registerTooltipGenerator(tooltip)
        ..tooltipStartListen()
        ..registerCustomPanelAbilityTooltip(asList(
            ABIL_CLEAVE_20,
            ABIL_IMMOLATION
            ))
        ..setNormalAbilities(commaList(ABIL_CLEAVE_20, ABIL_IMMOLATION))

        ..setAttack1Data(AttackType.Siege, 85, 5, 7, 1.6)

        ..setArmorData(ArmorType.Large, 5)
        ..setHitPointsMaximumBase(2000)

        ..setPointValue(120)
        ..setSummonedUnit()
        ..setGhostDeath()

        ..setSizeLarge()
        ..setNameEnhance("Q", "Infernal")
        ..setAutoPointValue()
        ..tooltipStopListen(true)

@compiletime function createPitLord()
    let tooltip = new UnitTooltipGenerator(
        abilTooltipMap.get(ABIL_HOWL_OF_TERROR) + "\n\n" +
        abilTooltipMap.get(ABIL_CLEAVE_30)
        )
    createSpawnedUnit(UNIT_PIT_LORD, UnitIds.pitlord, BUILDING_PIT_LORD)
        ..setSpeedBase(270)
        ..registerCustomPanelAbilityTooltip(asList(ABIL_CLEAVE_30, ABIL_HOWL_OF_TERROR))
        ..setNormalAbilities(commaList(
            ABIL_HOWL_OF_TERROR,
            ABIL_CLEAVE_30,
            ABIL_AC_HOWL_OF_TERROR
        ))
        ..setDefaultActiveAbility(commaList(ABIL_AC_HOWL_OF_TERROR))
        ..registerTooltipGenerator(tooltip)
        ..tooltipStartListen()

        ..setAttack1Data(AttackType.Normal, 140, 10, 7, 2)

        ..setArmorData(ArmorType.Large, 6)
        ..setHitPointsMaximumBase(3000)
        ..setMana(200)


        ..setAutoPointValue()
        ..setAutoBuildingCost()
        ..setSizeLarge()

        ..tooltipStopListen()

        ..setNameEnhance("R", "Pit Lord")

        ..setModelFileExt(Units.heroPitLord)
        ..setIconGameInterfaceExt(Icons.bTNPitLord)
        ..setUnitSoundSetExt(Soundsets.pitlord)
        ..setBuildingScalingValue(0.45)


@compiletime function createBuilder()
    createBuilder(UNIT_DEMON_BUILDER, UnitIds.chaospeon)
        ..setNameEnhance("D", "Demon Builder")
        ..setStructuresBuilt(commaList(
            BUILDING_FEL_HOUND,
            BUILDING_SUCCUBUS,
            BUILDING_FEL_GUARD,
            BUILDING_PIT_LORD,
            BUILDING_EREDAR_SORCERER,
            BUILDING_FEL_RITUALIST,
            BUILDING_MANA_SLAVE
        ))
