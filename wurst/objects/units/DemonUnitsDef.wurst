package DemonUnitsDef

// Standard libs imports:
import Assets
import ChannelAbilityPreset
import LinkedList

// Local imports:
import ArmySpawner
import BTAbilities
import ItemObjEditingCommon
import LocalObjectIDs
import UnitObjEditingCommon
import UnitTooltipGenerator


@compiletime function createFelHound()
    var tooltip = new UnitTooltipGenerator("Basic melee unit.")
    createSpawnedUnit(UNIT_FEL_HOUND, UnitIds.felstalker, BUILDING_FEL_HOUND)
        ..setSpeedBase(270)
        ..registerTooltipGenerator(tooltip)
        ..tooltipStartListen()

        ..setAttack1Data(AttackType.Pierce, 5, 5, 3, 1.7)

        ..setArmorData(ArmorType.Small, 2)
        ..setHitPointsMaximumBase(400)


        ..setSizeSmall()
        ..setAutoPointValue()
        ..setAutoBuildingCost()

        ..setNameEnhance("Q", "Felhound")
        ..tooltipStopListen()
        ..setUpgradeTo(asList(BUILDING_FEL_STALKER))
        ..setMana(0)

        ..setScalingValue(0.75)

        ..setBuildingScalingValue(0.6)
        ..setModelFileExt(Units.felhound)
        ..setIconGameInterfaceExt(Icons.bTNFelHound)
        ..setUnitSoundSetExt(Soundsets.felhound)

    tooltip = new UnitTooltipGenerator(abilTooltipMap.get(ABIL_MANA_BURN))
    createSpawnedUnit(UNIT_FEL_STALKER, UnitIds.purplefelstalker, BUILDING_FEL_STALKER)
        ..setSpeedBase(300)
        ..registerCustomPanelAbilityTooltip(ABIL_MANA_BURN)
        ..setNormalAbilities(commaList(ABIL_MANA_BURN, ABIL_AC_MANA_BURN))
        ..setDefaultActiveAbility(commaList(ABIL_AC_MANA_BURN))
        ..registerTooltipGenerator(tooltip)
        ..tooltipStartListen()

        ..setAttack1Data(AttackType.Pierce, 25, 5, 4, 1.4)

        ..setArmorData(ArmorType.Small, 3)
        ..setHitPointsMaximumBase(675)
        ..setMana(200)

        ..setAutoPointValue()
        ..setAutoBuildingCost()

        ..setSizeSmall()
        ..setNameEnhance("Z", "Fel Stalker")
        ..tooltipStopListen()

        ..setScalingValue(0.9)
        ..setBuildingScalingValue(0.7)
        ..setModelFileExt(Units.felstalkerPurple1)
        ..setIconGameInterfaceExt(Icons.bTNPurpleFelhound)
        ..setUnitSoundSetExt(Soundsets.felhound)
        ..setButtonPositionX(1)


@compiletime function createSuccubus()
    var tooltip = new UnitTooltipGenerator(
        abilTooltipMap.get(ABIL_CURSE) + "\n\n" +
        abilTooltipMap.get(ABIL_BOUNCE_2_50)
        )
    createSpawnedUnit(UNIT_SUCCUBUS, UnitIds.succubus, BUILDING_SUCCUBUS)
        ..setSpeedBase(270)
        ..setAttack1MaximumNumberofTargets(2)
        ..setAttack1DamageLossFactor(0.5)
        ..registerTooltipGenerator(tooltip)
        ..registerCustomPanelAbilityTooltip(asList(ABIL_CURSE, ABIL_BOUNCE_2_50))
        ..setNormalAbilities(commaList(
            ABIL_CURSE, ABIL_BOUNCE_2_50
        ))
        ..setDefaultActiveAbility(commaList(ABIL_CURSE))
        ..tooltipStartListen()

        ..setAttack1Data(AttackType.Magic, 15, 5, 3, 1.7)
        ..setAttack1Range(500)
        ..setAttack1ProjectileArt(Abilities.wingedSerpentMissile)
        ..setAttack1ProjectileSpeed(STANDARD_PROJECTILE_SPEED)
        ..setAttack1WeaponSound(WeaponSound.Nothing)

        ..setArmorData(ArmorType.Unarmored, 2)
        ..setHitPointsMaximumBase(200)
        ..setMana(200)
        ..setManaRegeneration(1)


        ..setSizeSmall()
        ..setAutoPointValue()
        ..setAutoBuildingCost()
        ..setNameEnhance("W", "Succubus")
        ..tooltipStopListen()

        ..setBuildingScalingValue(0.6)
        ..setModelFileExt(Units.demoness1)
        ..setIconGameInterfaceExt(Icons.bTNDemoness)
        ..setUnitSoundSetExt(Soundsets.demoness)

    tooltip = new UnitTooltipGenerator(
            abilTooltipMap.get(ABIL_SILENCE) + "\n\n" +
            abilTooltipMap.get(ABIL_BOUNCE_4_30)
            )
    let itm = createBasicItem(ITEM_MAIDEN_OF_PAIN)
    createSpawnedUnit(UNIT_MAIDEN_OF_PAIN, UnitIds.maidenofpain)
        ..setSpeedBase(270)
        ..registerCustomPanelAbilityTooltip(asList(ABIL_SILENCE, ABIL_BOUNCE_4_30))
        ..setNormalAbilities(commaList(ABIL_SILENCE, ABIL_AC_SILENCE, ABIL_BOUNCE_4_30))
        ..setDefaultActiveAbility(commaList(ABIL_AC_SILENCE))
        ..registerItemDef(itm, ItemModifierType.Addition)
        ..registerTooltipGenerator(tooltip)
        ..tooltipStartListen()


        ..setAttack1ProjectileSpeed(STANDARD_PROJECTILE_SPEED)
        ..setAttack1Data(AttackType.Magic, 70, 10, 4, 1.4)
        ..setAttack1Range(500)
        ..setAttack1ProjectileArt(Abilities.gargoyleMissile)
        ..setAttack1MaximumNumberofTargets(4)
        ..setAttack1DamageLossFactor(0.3)
        ..setAttack1WeaponSound(WeaponSound.Nothing)

        ..setArmorData(ArmorType.Unarmored, 6)
        ..setHitPointsMaximumBase(750)
        ..setMana(200)

        ..setSizeSmall()
        ..setItemCostUnit(0, 1000, 1)
        ..tooltipStopListen(true, itm)

        ..setNameEnhance("X", "Maiden of Pain")
        ..setIconGameInterfaceExt(Icons.bTNBlueDemoness)


    tooltip = new UnitTooltipGenerator(
            abilTooltipMap.get(ABIL_MANA_SHARE)
            )
    createSpawnedUnit(UNIT_MANA_SLAVE, UnitIds.draeneidisciple, BUILDING_MANA_SLAVE)
        ..setSpeedBase(270)
        ..registerTooltipGenerator(tooltip)
        ..registerCustomPanelAbilityTooltip(asList(ABIL_MANA_SHARE))
        ..setNormalAbilities(commaList(
            ABIL_MANA_SHARE, ABIL_AC_MANA_SHARE
        ))
        ..setDefaultActiveAbility(commaList(ABIL_AC_MANA_SHARE))
        ..tooltipStartListen()

        ..setAttack1Data(AttackType.Magic, 10, 5, 1, 2)
        ..setAttack1Range(650)
        ..setScaleProjectiles(true)
        ..setAttack1ProjectileArt(Abilities.druidoftheTalonMissile)
        ..setAttack1WeaponType(WeaponType.Missile)
        ..setAttack1ProjectileSpeed(STANDARD_PROJECTILE_SPEED)

        ..setArmorData(ArmorType.Unarmored, 0)
        ..setHitPointsMaximumBase(100)
        ..setMana(400)
        ..setManaRegeneration(1)


        ..setSizeSmall()
        ..setAutoPointValue()
        ..setAutoBuildingCost()

        ..setNameEnhance("A", "Mana Slave")
        ..tooltipStopListen()

        ..setBuildingScalingValue(0.6)
        ..setModelFileExt(Units.dranaiMage)
        ..setIconGameInterfaceExt(Icons.bTNDranaiMage)
        ..setUnitSoundSetExt(Soundsets.dranai)


@compiletime function createFelGuard()
